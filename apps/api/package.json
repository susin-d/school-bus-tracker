{
  "name": "@school-bus/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b ../../packages/shared/tsconfig.json tsconfig.json",
    "create:system-admin": "tsx src/scripts/create-system-admin.ts",
    "check:dependencies": "tsx src/scripts/check-dependencies.ts",
    "send:test-email": "tsx src/scripts/send-test-email.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -b tsconfig.json --pretty false",
    "rls:seed": "tsx src/scripts/seed-rls-fixtures.ts",
    "test": "vitest run",
    "test:rls": "vitest run tests/rls.integration.test.ts",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@school-bus/shared": "workspace:*",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^24.3.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
