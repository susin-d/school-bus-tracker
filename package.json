{
  "name": "school-bus-bridge",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/api",
    "apps/admin-web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm run -w @school-bus/api dev",
    "dev:api": "npm run -w @school-bus/api dev",
    "dev:admin": "npm run -w @school-bus/admin-web dev",
    "dev:mobile": "flutter run -d chrome apps/parents-app/lib/main.dart",
    "lint": "npm run --workspaces lint",
    "start": "npm run -w @school-bus/api start",
    "typecheck": "npm run --workspaces typecheck"
  }
}

